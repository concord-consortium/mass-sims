{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    // Restricts ambient types to vite/client (for typed *.module.scss / asset imports in
    // components). Note: an explicit list opts OUT of auto-including other @types/* — add
    // them here if needed (e.g. "node").
    "types": ["vite/client"]
  },
  "include": ["src/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
